# One-time deployer key (NOT the Safe). Fund with Sepolia test ETH only.
PRIVATE_KEY=0x...

# Sepolia RPC endpoint (Infura, Alchemy, etc.)
RPC_URL=https://sepolia.infura.io/v3/<YOUR_KEY>

# Optional: enables auto-verify in scripts/deploy.ts
ETHERSCAN_API_KEY=your_etherscan_api_key

# Token metadata
TOKEN_NAME=Team Payout Token
TOKEN_SYMBOL=TPAY
TOKEN_CONTRACT_URI=https://example.com/team-payout-token.json

# Set AFTER creating the Safe (see ../README.md); used by transferOwnershipToSafe.ts
SAFE_ADDRESS=0x...
