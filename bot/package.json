{
  "name": "zamance-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-first private payout bot backend (Sepolia + Zama FHEVM + Safe multisig)",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "worker": "ts-node src/workers/approvalPoller.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@safe-global/api-kit": "^5.0.1",
    "@safe-global/protocol-kit": "^8.0.1",
    "@safe-global/types-kit": "^4.0.1",
    "@slack/bolt": "^4.2.0",
    "@zama-fhe/relayer-sdk": "^0.4.3",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "groq-sdk": "^1.3.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
